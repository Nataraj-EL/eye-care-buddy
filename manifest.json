{
  "manifest_version": 3,
  "name": "EyeCare Buddy",
  "version": "1.0.0",
  "description": "Track browsing time and remind you to follow the 20-20-20 rule for healthier eyes.",
  "permissions": ["storage", "notifications", "alarms", "tabs"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "EyeCare Buddy - Take a Break !",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
